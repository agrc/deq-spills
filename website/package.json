{
  "name": "@ugrc/deq-spills",
  "version": "3.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "check": "tsc -b",
    "copy:arcgis": "cpy \"./node_modules/@arcgis/core/assets/**\" ./public/assets",
    "dev": "concurrently 'cd functions && pnpm run build:watch' 'wait-on ./functions/lib/src/index.js && pnpm dev:firebase' 'wait-on http://127.0.0.1:4000 && pnpm dev:vite'",
    "dev:firebase": "./scripts/start-emulators.sh",
    "dev:vite": "vite",
    "format": "prettier . --write",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "pnpm run dev",
    "test": "vitest"
  },
  "browserslist": {
    "production": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@arcgis/core": "^4.34.8",
    "@tanstack/react-query": "^5.100.5",
    "@ugrc/eslint-config": "^1.3.0",
    "@ugrc/esri-theme-toggle": "^1.1.2",
    "@ugrc/layer-selector": "^6.4.0",
    "@ugrc/utah-design-system": "^1.35.0",
    "@ugrc/utilities": "^3.1.1",
    "firebase": "^12.12.1",
    "ky": "^2.0.2",
    "lodash.startcase": "^4.4.0",
    "react": "^19.2.5",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-fast-compare": "^3.2.2",
    "react-stately": "^3.46.0",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@types/lodash.startcase": "^4.4.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@ugrc/tailwind-preset": "^1.2.0",
    "@ugrc/tsconfigs": "^1.0.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cpy-cli": "^7.0.0",
    "eslint": "^9.39.2",
    "firebase-tools": "^15.15.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "tailwindcss": "^3.4.19",
    "tailwindcss-react-aria-components": "^1.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-package-version": "^1.1.0",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  }
}
